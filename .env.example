# --- AI Image Generation (optional) ---
# Leave unset to use the built-in deterministic mock (no keys, fully playable).
# Set to "openai" to call the OpenAI Images API.
IMAGE_PROVIDER=
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# --- Image Similarity (optional) ---
# Currently only the mock scorer is implemented. Swap compareSimilarity in
# lib/ai/compareSimilarity.ts to wire a real vision/embedding model.
SIMILARITY_PROVIDER=
