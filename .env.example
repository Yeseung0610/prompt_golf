# --- OpenAI (이미지 생성 + 이미지 유사도 비교) ---
# 프롬프트 → OpenAI 이미지 생성, 생성 이미지 ↔ 목표 이미지 유사도 비교(OpenAI 비전).
# https://platform.openai.com/api-keys 에서 키를 발급해 넣으세요.
# 키가 없거나 호출 실패 시 자동으로 mock(오프라인)으로 폴백됩니다.
OPENAI_API_KEY=your-openai-api-key-here
# 이미지 생성 모델 (기본 gpt-image-1). dall-e-3 등으로 교체 가능.
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
# 유사도 비교용 비전 모델 (기본 gpt-4o).
OPENAI_VISION_MODEL=gpt-4o

# 유사도 비교 프로바이더 (기본 openai). 강제로 mock을 쓰려면 "mock".
SIMILARITY_PROVIDER=openai
