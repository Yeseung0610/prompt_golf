# --- Google Gemini (HTML 생성 + 이미지 유사도 비교) ---
# 무료 티어로 동작합니다 (gemini-2.5-flash, 멀티모달, 약 1,500 req/day, 카드 불필요).
# https://aistudio.google.com/apikey 에서 API 키를 발급받아 넣으세요.
# 키가 없으면 자동으로 mock(오프라인)으로 폴백되어 게임은 계속 플레이됩니다.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 프로바이더 선택 (기본 gemini). 강제로 mock을 쓰려면 "mock".
HTML_PROVIDER=gemini
SIMILARITY_PROVIDER=gemini
